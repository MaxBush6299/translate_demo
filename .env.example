# Copy this file to `.env` and fill in values from your Bicep deployment outputs.
# Run: az deployment group show -g rg-translatedemo -n main --query properties.outputs

# Translator data-plane endpoint, e.g. https://cog-xltdemo-xxxxxx.cognitiveservices.azure.com/
TRANSLATOR_ENDPOINT=

# Storage account name (no URL), e.g. stxltdemoxxxxxx
STORAGE_ACCOUNT_NAME=

# Blob container that holds source/, glossaries/, target/
CONTAINER_NAME=documents

# Virtual folder prefixes inside the container.
SOURCE_PREFIX=source/
GLOSSARY_BLOB_NAME=glossaries/glossary_v1-en-es.tsv
TARGET_PREFIX_NO_GLOSSARY=target/no-glossary/
TARGET_PREFIX_WITH_GLOSSARY=target/with-glossary/

# Translation language codes.
SOURCE_LANGUAGE=en
TARGET_LANGUAGE=es

# Local inputs/outputs (paths relative to repo root).
LOCAL_SOURCE_PDF=source_docs/osha_excerpt.pdf
LOCAL_GLOSSARY_TSV=glossary/glossary_v1-en-es.tsv
LOCAL_OUTPUT_DIR=output
