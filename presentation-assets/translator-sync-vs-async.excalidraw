      "updated": 1,
      "link": null,
      "locked": false,
      "text": "The decision starts with file type and workflow model.\nSupported single file formats can use synchronous translation. PDF and storage based jobs use asynchronous batch translation.",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 34
    },
